SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=YOUR_SQUARE_ACCESS_TOKEN
SQUARE_LOCATION_ID=YOUR_SQUARE_LOCATION_ID
SQUARE_WEBHOOK_SIGNATURE_KEY=YOUR_SQUARE_WEBHOOK_SIGNATURE_KEY
SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-ngrok-or-domain/webhooks/square
SQUARE_ENABLE_CASH_APP_PAY=1
SQUARE_ENABLE_ACH_REQUEST=1
APP_BASE_URL=http://127.0.0.1:5000
BACKEND_BASE_URL=http://127.0.0.1:5000
FRONTEND_BASE_URL=http://127.0.0.1:5501/frontend
FLASK_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/auth/google/callback
